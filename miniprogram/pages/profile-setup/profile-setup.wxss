/* pages/profile-setup/profile-setup.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.setup-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  display: block;
}

.setup-content {
  text-align: center;
}

.setup-text {
  font-size: 32rpx;
  color: #666;
  display: block;
  margin-bottom: 60rpx;
}

.btn-home {
  background-color: #007aff;
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  border: none;
}

.btn-home:hover {
  background-color: #0056cc;
}