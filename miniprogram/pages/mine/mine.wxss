/* pages/mine/mine.wxss */
.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: -1; /* 让图片位于所有内容的底层 */
}
.all{
  display:flex;
  flex-direction:column;
}
.top{
  display:flex;
  margin: 30rpx;
}
.topshowimage{
  flex: 2;
  display: flex;
  justify-content: center;
  align-items: center;
}
.topshowdetail{
  flex:3;
}
.user_icon{
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
}
.user_info_nickname{
  font-size: 32rpx;
}
.user_info_phone{
  font-size: 32rpx;
}
.user_love{
  font-size: 32rpx;
  word-wrap: break-word;
}
.user_love2{
  font-size: 32rpx;
  word-wrap: break-word;
  color:gray;
}
.user_detail{
  border-top: 5rpx solid #ccc;
  border-bottom: 5rpx solid #ccc;
}
.userinformation{
  display:flex;
  flex-direction: row;
}
.item{
  flex:1;
  display: flex;
  justify-content: center;
  align-items: center;
}
.content{
  flex:2;
  display: flex;
}
.itemdetail{
  font-size: 32rpx;
}
.contentdetail{
  font-size: 32rpx;
}
.contentdetail2{
  font-size: 32rpx;
  color:gray;
}
.myword{
  margin:30rpx;
}
.message{
  border: 5rpx solid #78161E;
  border-radius: 15rpx;
  margin: 30rpx;
  padding:8rpx;
  width:665rpx;
  min-height: 320rpx;
  height:auto !important;
  font-size: 27rpx;
}
.button{
  background-color:#78161E !important;
  color:snow !important;
  border-radius: 12rpx;
  border-style:hidden !important;
}
.tips{
  display: flex;
  align-items: center;
  justify-content: center; 
  color:gray;
  height:800rpx;
}
.first_tab .dancers {
  display: flex;
  border-bottom: 5rpx solid #ccc;
}
.first_tab .dancers .dancerImage {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}
.first_tab .dancers .dancerImage image {
  width: 70%;
}
.first_tab .dancers .dancerInfo {
  flex: 2;
}
.first_tab .dancers .dancerInfo .dancerName {
  font-size: 27rpx;
}
.first_tab .dancers .dancerInfo .dancerGender {
  font-size: 27rpx;
}
.first_tab .dancers .dancerInfo .dancerSchool {
  font-size: 27rpx;
}
.first_tab .dancers .dancerInfo .dancerMsg {
  font-size: 27rpx;
}
.first_tab .dancers .dancerInfo .dancerMsg2 {
  font-size: 27rpx;
  color:gray;
}
.user_icon2{
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
}
.buttoninvite{
  position:absolute;
  right:0;
  width: 110rpx !important;
  height:50rpx !important;
  font-size: 28rpx;
  padding: 0;
  margin: 0 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: gold !important;
}
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}
.loading-gif {
  width: 100rpx;
  height: 100rpx;
}

/* 按钮容器样式 */
.wrapbutton {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin: 40rpx 30rpx;
}

/* 退出登录按钮样式 */
.logout-btn {
  background-color: #d93025 !important;
  color: white !important;
  border-radius: 12rpx;
  border-style: hidden !important;
}
.message-selfie {
  width: 100%;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}
.message-text {
  line-height: 1.5;
}
/* 全屏半透明遮罩 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.popup-content {
  position: relative;
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
}


.ticket-name {
  position: absolute;   
  top: 34.5%;            /* 距离图片顶部的距离 (建议用百分比，图片缩放时位置才不会跑偏) */
  left: 29%;           
  font-size: 36rpx;
  color: #25305c;      
  font-weight: bold;
  letter-spacing: 0rpx; 
  font-family: '楷体', 'KaiTi', serif; 
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.success-img {
  width: 100%;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.5);
}

.close-btn {
  position: absolute;
  top: -70rpx;
  right: 0;
  color: #fff;
  font-size: 60rpx;
  line-height: 1;
  padding: 10rpx;
}
