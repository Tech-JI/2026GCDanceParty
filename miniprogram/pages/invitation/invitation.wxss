/* 邀请管理页面样式 */
.page-container {
  min-height: 100vh;
  position: relative; /* 为里面的绝对定位提供参照 */
}

/* 强制把图片钉在屏幕最底层，铺满全屏 */
.bg-img {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; /* -1 代表放在最底层，不会挡住你的按钮和文字 */
}

/* 标签页导航 */
.tab-nav {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 0 0 20rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  flex: 1;
  padding: 30rpx 20rpx;
  text-align: center;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 2rpx;
}

.tab-text {
  font-size: 32rpx;
}

.tab-badge {
  background: #ff4757;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 10rpx;
  min-width: 20rpx;
  text-align: center;
  line-height: 1;
}

/* 内容容器 */
.content-container {
  padding: 0 20rpx;
  height: calc(100vh - 140rpx);
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 邀请列表 */
.invitation-list {
  height: 100%;
}

.invitation-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 邀请头部 */
.invitation-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.sender-info,
.receiver-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sender-name,
.receiver-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.sender-id,
.receiver-id {
  font-size: 24rpx;
  color: #666;
}

/* 状态标签 */
.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background: #ffeaa7;
  color: #d63031;
}

.status-accepted {
  background: #00b894;
  color: #fff;
}

.status-rejected {
  background: #ddd;
  color: #666;
}

.status-auto_rejected {
  background: #fab1a0;
  color: #e17055;
}

/* 邀请内容 */
.invitation-content {
  margin-bottom: 20rpx;
}

.message {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 8rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.reply {
  font-size: 26rpx;
  color: #555;
  background: #e3f2fd;
  padding: 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  border-left: 4rpx solid #2196f3;
}

/* 邀请操作按钮 */
.invitation-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.action-btn {
  min-width: 120rpx;
  height: 60rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: none;
}

.reject-btn {
  background: #f5f5f5;
  color: #666;
}

.accept-btn {
  background: linear-gradient(90deg, #667eea, #764ba2);
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  text-align: center;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.3;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
  margin-bottom: 40rpx;
}

.go-search-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #667eea;
  border-radius: 25rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  border: none;
}

/* 回复模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.reply-modal {
  background: #fff;
  width: 90%;
  max-width: 600rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.6;
}

.modal-content {
  padding: 30rpx;
}

.invitation-info {
  margin-bottom: 24rpx;
}

.sender-label {
  font-size: 28rpx;
  color: #666;
}

.original-message {
  margin-bottom: 24rpx;
}

.message-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.message-content {
  font-size: 30rpx;
  color: #333;
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 8rpx;
  line-height: 1.5;
}

.reply-input-section {
  margin-top: 24rpx;
}

.reply-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.reply-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f8f9fa;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  resize: none;
}

.reply-textarea:focus {
  border-color: #667eea;
  background: #fff;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.modal-btn.reject-btn {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.accept-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}