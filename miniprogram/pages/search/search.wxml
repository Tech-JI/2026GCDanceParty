<!-- 搜索舞伴页面 -->
<view class="page-container">
  <image class="bg-img" src="/icons/background_invitation.jpg" mode="aspectFill"></image>
  <!-- 搜索区域 -->
  <view class="search-section">
    <view class="search-title">搜索舞伴</view>
    <view class="search-description">输入对方的数字ID来搜索舞伴</view>
    
    <view class="search-input-group">
      <input 
        class="search-input" 
        type="number" 
        placeholder="请输入数字ID" 
        value="{{searchId}}"
        bindinput="onSearchIdInput"
      />
      <button 
        class="search-button" 
        bindtap="onSearchTap"
        disabled="{{isSearching}}"
      >
        {{isSearching ? '搜索中..' : '搜索'}}
      </button>
    </view>
  </view>

  <!-- 搜索结果区域 -->
  <view class="result-section" wx:if="{{showResult}}">
    <view class="result-header">
      <text class="result-title">搜索结果</text>
      <button class="clear-button" bindtap="onClearResult">清除</button>
    </view>

    <view class="user-card">
      <!-- 用户头像 -->
      <view class="avatar-section">
        <image 
          class="avatar" 
          src="{{searchResult.userInfo.image || '/icons/person.png'}}"
          mode="aspectFill"
        />
        <view class="partner-status">
          <text class="status-text {{searchResult.userInfo.hasPartner ? 'has-partner' : 'no-partner'}}">
            {{searchResult.userInfo.hasPartner ? '已有舞伴' : '无舞伴'}}
          </text>
        </view>
      </view>

      <!-- 用户信息 -->
      <view class="info-section">
        <view class="basic-info">
          <view class="name">{{searchResult.userInfo.name}}</view>
          <view class="numeric-id">ID: {{searchResult.userInfo.numericId}}</view>
        </view>
        <!-- 此处曾经有过搜索对象的详细信息 因紧急维修弃用 详情查看云函数-->
        

      </view>
    </view>

    <!-- 邀请区呢-->
    <view class="invite-section" wx:if="{{searchResult.canInvite}}">
      <view class="invite-title">发送邀请</view>
      <textarea 
        class="invite-message" 
        placeholder="请输入邀请消息，让对方了解您"
        value="{{inviteMessage}}"
        bindinput="onInviteMessageInput"
        maxlength="100"
      />
      <view class="message-tip">{{inviteMessage.length}}/100</view>
      <button class="invite-button" bindtap="onSendInvitation">
        发送邀请      </button>
    </view>

    <!-- 无法邀请提呢-->
    <view class="no-invite-tip" wx:if="{{!searchResult.canInvite}}">
      <text class="tip-text">
        {{searchResult.userInfo.hasPartner ? '该用户已有舞伴' : '该用户不接受邀请'}}
      </text>
    </view>
  </view>

  <!-- 空状呢-->
  <view class="empty-state" wx:if="{{!showResult && !isSearching}}">
    <image class="empty-icon" src="/icons/search.png" mode="aspectFit" />
    <text class="empty-text">输入数字ID搜索舞伴</text>
    <text class="empty-hint">您可以通过数字ID快速找到心仪的舞伴</text>
  </view>
</view>
  

