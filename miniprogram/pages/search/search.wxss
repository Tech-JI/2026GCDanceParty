/* 搜索舞伴页面样式 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

/* 搜索区域 */
.search-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.search-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.search-description {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
}

.search-input-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  border: 2rpx solid transparent;
}

.search-input:focus {
  border-color: #667eea;
  background: #fff;
}

.search-button {
  height: 80rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.search-button[disabled] {
  background: #ccc;
}

/* 搜索结果区域 */
.result-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eee;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.clear-button {
  background: #f0f0f0;
  color: #666;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border: none;
}

/* 用户卡片 */
.user-card {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.partner-status {
  display: flex;
  align-items: center;
}

.status-text {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.has-partner {
  background: linear-gradient(90deg, #ff9a9e 0%, #fecfef 100%);
  color: #fff;
}

.no-partner {
  background: linear-gradient(90deg, #a8edea 0%, #fed6e3 100%);
  color: #333;
}

/* 用户信息 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.basic-info {
  text-align: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.numeric-id {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

.detail-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  min-width: 140rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.signature {
  background: #f0f7ff;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
}

.signature-label {
  font-size: 24rpx;
  color: #666;
}

.signature-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: block;
  margin-top: 8rpx;
}

/* 邀请区域 */
.invite-section {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 2rpx solid #eee;
}

.invite-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.invite-message {
  width: 100%;
  min-height: 120rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.invite-message:focus {
  border-color: #667eea;
  background: #fff;
}

.message-tip {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin: 8rpx 0 24rpx 0;
}

.invite-button {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

/* 无法邀请提示 */
.no-invite-tip {
  margin-top: 40rpx;
  padding: 30rpx;
  background: #fff3cd;
  border-radius: 12rpx;
  text-align: center;
}

.tip-text {
  font-size: 28rpx;
  color: #856404;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
}