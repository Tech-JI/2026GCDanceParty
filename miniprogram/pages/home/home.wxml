<!-- 这个页面时首页页面，显示所有已经登录的用户 -->
<block wx:if="{{done==false}}">
  <view class="loading-container">
    <image class="loading-gif" src="{{spinnerGifUrl}}" mode="aspectFit" />
  </view>

</block>
<view class="popup-mask" wx:if="{{showSuccessPopup}}" bindtap="closePopup">
  <view class="popup-content" catchtap="preventBubbling">
    <image src="{{popupImageUrl}}" mode="widthFix" class="success-img"></image>
    <view class="ticket-name">{{popupUserName}}</view>
    <view class="close-btn" bindtap="closePopup">×</view>
  </view>
</view>
<block wx:if="{{done==true}}">
  <image class="background-image" src="{{backgroundImageUrl}}" mode="aspectFill"></image>
  <view class="page-container">
    <view class="search_input" style="position: fixed; width:735rpx">
      <navigator url="../../pages/search/search" open-type="navigate">{{text.search}}</navigator>
      <view class="tabs_title">
        <block wx:for="{{tabs}}" wx:key="index">
          <Tabs tabs="{{tabs}}" binditemChange="handleItemChange" class="test"></Tabs>
        </block>
      </view>
      <text decode="{{true}}">&nbsp;</text>
    </view>
    <text decode="{{true}}">&nbsp;</text>
    <text decode="{{true}}">&nbsp;</text>
    <text decode="{{true}}">&nbsp;</text>

    <scroll-view class="scroll-container" scroll-y="true" style="height: 90vh; margin-top: 10vh;">

      <block wx:if="{{tabs[0].isActive}}">

        <view wx:for="{{dataobjWithoutPartner}}" wx:key="_id">
          <view class="first_tab">
            <navigator class="dancers" url="../../pages/view/view?personid={{item._id}}" open-type="navigate">
              <view class="dancerImage">
                <image mode="heightFix" class="user_icon" src="{{item.image || '/icons/person.png'}}"></image>
                <view class="noPartner">暂无舞伴</view>
              </view>
              <view class="dancerInfo">
                <text decode="{{true}}">&nbsp;</text>
                <view class="dancerName">姓名：{{item.name}}</view>
                <view class="dancerGender">性别：{{item.gender}}</view>
                <view class="dancerSchool">学校学院：{{item.school}}</view>
                <view class="dancerMsg" wx:if="{{item.love!=''}}">Ta喜欢：{{item.love}}</view>
                <view class="dancerMsg2" wx:if="{{item.love==''}}">Ta还没填写喜欢的内容</view>
                <text decode="{{true}}">&nbsp;</text>
              </view>
              <image src="{{cornerImageUrl}}" class="corner" />
            </navigator>
          </view>
        </view>

        <view wx:for="{{dataobjWithPartner}}" wx:key="_id">
          <view class="first_tab">
            <navigator class="dancers" url="../../pages/view/view?personid={{item._id}}" open-type="navigate">
              <view class="dancerImage">
                <image mode="heightFix" class="user_icon" src="{{item.image || '/icons/person.png'}}"></image>
                <view class="hasPartner">已有舞伴</view>
              </view>
              <view class="dancerInfo">
                <text decode="{{true}}">&nbsp;</text>
                <view class="dancerName">姓名：{{item.name}}</view>
                <view class="dancerGender">性别：{{item.gender}}</view>
                <view class="dancerSchool">学校学院：{{item.school}}</view>
                <view class="dancerMsg" wx:if="{{item.love!=''}}">Ta喜欢：{{item.love}}</view>
                <view class="dancerMsg2" wx:if="{{item.love==''}}">Ta还没填写喜欢的内容</view>
                <text decode="{{true}}">&nbsp;</text>
              </view>
              <image src="{{cornerImageUrl}}" class="corner" />
            </navigator>
          </view>
        </view>
      </block>


