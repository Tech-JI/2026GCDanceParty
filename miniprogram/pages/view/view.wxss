/* pages/mine/mine.wxss */
.all{
  display:flex;
  flex-direction:column;
}
.top{
  display:flex;
  margin: 30rpx;
}
.topshowimage{
  flex: 2;
  display: flex;
  justify-content: center;
  align-items: center;
}
.topshowdetail{
  flex:3;
}
.user_icon{
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
}
.user_info_nickname{
  font-size: 32rpx;
}
.user_info_phone{
  font-size: 32rpx;
}
.user_love{
  font-size: 32rpx;
  word-wrap: break-word;
}
.user_love2{
  font-size: 32rpx;
  word-wrap: break-word;
  color:gray;
}
.user_detail{
  border-top: 5rpx solid #ccc;
  border-bottom: 5rpx solid #ccc;
}
.userinformation{
  display:flex;
  flex-direction: row;
}
.item{
  flex:1;
  display: flex;
  justify-content: center;
  align-items: center;
}
.content{
  flex:2;
  display: flex;
}
.itemdetail{
  font-size: 32rpx;
}
.contentdetail{
  font-size: 32rpx;
}
.contentdetail2{
  font-size: 32rpx;
  color:gray;
}
.myword{
  margin:50rpx;
}
.message{
  border: 5rpx solid #78161E;
  border-radius: 15rpx;
  padding:8rpx;
  width: 650rpx;         
  margin: 0 auto 30rpx;  

  min-height: 320rpx;
  height:auto !important;
  font-size: 27rpx;
}

.button{
  margin:20rpx;
  background-color:#78161E !important;
  color:snow !important;
  border-radius: 10rpx;
  border-style:hidden !important;
}
.wordcount{
  display:flex;
  align-items: flex-end;
  justify-content: flex-end;
  color:gray;
  font-size: 18rpx;
}
.textbox{
  width:100%;
  height:300rpx;
  font-size: 27rpx;
}
.tips{
  display: flex;
  align-items: center;
  justify-content: center; 
  color:gray;
  height:800rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}
.loading-gif {
  width: 100rpx;
  height: 100rpx;
}
.message-selfie {
  width: 690rpx;          
  margin: 0 auto 20rpx;  
  border-radius: 10rpx;
  display: block;         
}
.message-text {
  line-height: 1.5;
}
.message {
  width: 690rpx;         
  margin: 0 auto 30rpx;  
  box-sizing: border-box; 
  
  border: 5rpx solid #78161E; 
  border-radius: 15rpx;
  padding: 20rpx;         
  min-height: 320rpx;    
  height: auto !important; 
}

.message-selfie {
  width: 100%;          
  display: block;       
  border-radius: 10rpx; 
  margin-bottom: 20rpx; 
}
.message-text {
  font-size: 28rpx;
  color: #333; 
  line-height: 1.5; 
  word-wrap: break-word; 
}


