<!-- 会员支付页面 -->
<view class="page-container">
  <image class="bg-img" src="/icons/background_invitation.jpg" mode="aspectFill"></image>
  <!-- 用户信息区域 -->
  <view class="user-info-section">
    <view class="info-title">用户信息</view>
    
    <view class="user-card">
      <view class="avatar-section">
        <image 
          class="avatar" 
          src="{{currentUser.avatar || currentUser.image || '/icons/person.png'}}"
          mode="aspectFill"
        />
        <view class="status-badge status-{{paymentStatus}}">
          {{paymentStatus === 'unpaid' ? '未激活' : paymentStatus === 'processing' ? '审核中' : '已激活'}}
        </view>
      </view>

      <view class="user-details">
        <view class="detail-item">
          <text class="label">姓名:</text>
          <text class="value">{{currentUser.name}}</text>
        </view>
        <view class="detail-item">
          <text class="label">数字ID:</text>
          <text class="value">{{currentUser.numericId}}</text>
        </view>
        <view class="detail-item">
          <text class="label">学校:</text>
          <text class="value">{{currentUser.school}}</text>
        </view>
        <view class="detail-item">
          <text class="label">手机号：</text>
          <text class="value">{{currentUser.phone}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 支付状态区域-->
  <view class="payment-status-section">
    <view class="status-title">报名状态</view>
    
    <!-- 未支付状态-->
    <view class="status-card" wx:if="{{paymentStatus === 'unpaid'}}">
      <view class="status-content">
        <image class="status-icon" src="/icons/fail.png" mode="aspectFit" />
        <text class="status-text">您还未报名成功</text>
        <text class="status-desc">扫码支付即可激活所有功能</text>
      </view>
      
      <view class="payment-info">
        <view class="price-section">
          <text class="price-label">报名费用</text>
          <text class="price-amount">¥{{paymentAmount}}</text>
        </view>
        
        <button 
          class="payment-btn" 
          bindtap="onShowPaymentQR"
        >
          扫码支付
        </button>
      </view>
    </view>

    <!-- 审核中状态-->
    <view class="status-card" wx:if="{{paymentStatus === 'processing'}}">
      <view class="status-content">
        <image class="status-icon processing" src="/icons/spinner.gif" mode="aspectFit" />
        <text class="status-text">支付审核中</text>
        <text class="status-desc">管理员正在手动核销您的支付与PUQ截图</text>
      </view>
      
      <button 
        class="check-btn" 
        bindtap="onCheckPaymentStatus"
      >
        查询状态
      </button>
    </view>

    <!-- 已激活状态-->
    <view class="status-card" wx:if="{{paymentStatus === 'activated'}}">
      <view class="status-content">
        <image class="status-icon success" src="/icons/home.png" mode="aspectFit" />
        <text class="status-text">已报名成功</text>
        <text class="status-desc">恭喜！您可以使用所有功能</text>
      </view>
      
      <button 
        class="activated-btn" 
        bindtap="navigateToHome"
      >
        开始使用
      </button>
    </view>
  </view>

  <!-- 会员权益说明 -->
  <view class="benefits-section">
    <view class="benefits-title">报名权益</view>
    <view class="benefits-list">
      <view class="benefit-item">
        <view class="benefit-icon">🎯</view>
        <text class="benefit-text">使用数字ID搜索功能</text>
      </view>
      <view class="benefit-item">
        <view class="benefit-icon">💌</view>
        <text class="benefit-text">发送和接收舞伴邀请</text>
      </view>
      <view class="benefit-item">
        <view class="benefit-icon">🔐</view>
        <text class="benefit-text">完整的隐私保护设置</text>
      </view>
     
    </view>
  </view>
</view>

<!-- 支付二维码模态框 -->
<view class="modal-overlay" wx:if="{{showPaymentModal}}" bindtap="onClosePaymentModal">
  <view class="payment-modal" catchtap="">
    <view class="modal-header">
      <text class="modal-title">扫码支付</text>
      <image class="close-btn" src="/icons/refresh.png" bindtap="onClosePaymentModal" />
    </view>

    <scroll-view class="modal-content" scroll-y>
      <!-- 支付二维码-->
      <view class="qr-section">
        <image class="qr-code" src="/icons/payment.jpg" mode="aspectFit" />
        <text class="qr-desc">请使用微信扫码支付</text>
      </view>

      <!-- 订单信息 -->
      <view class="order-section">
        <view class="order-item">
          <text class="order-label">订单号：</text>
          <text class="order-value">{{orderNumber}}</text>
        </view>
        <view class="order-item">
          <text class="order-label">支付金额:</text>
          <text class="order-value price">¥{{paymentAmount}}</text>
        </view>
        <view class="order-item">
          <text class="order-label">用户姓名:</text>
          <text class="order-value">{{currentUser.name}}</text>
        </view>
      </view>

      <!-- 支付说明 -->
      <view class="proof-section">
        <view class="proof-title">PUQ 集赞截图</view>
        <view class="proof-desc">请上传您完成 PUQ 集赞的截图，管理员将与支付记录一起核销。</view>
        <button class="proof-upload-btn" bindtap="onChoosePuqProof" loading="{{uploadingProof}}">
          {{puqProofFileId ? '重新上传截图' : '上传PUQ截图'}}
        </button>
        <image wx:if="{{puqProofPreview}}" class="proof-preview" src="{{puqProofPreview}}" mode="aspectFit" />
        <text wx:if="{{puqProofFileId}}" class="proof-success">截图已上传，可提交审核</text>
      </view>

      <!-- 支付说明 -->
      <view class="payment-notice">
        <text class="notice-text">
          支付完成并上传PUQ截图后，请点击下方按钮提交，管理员会手动核销并在24小时内处理
        </text>
      </view>
    </scroll-view>

    <view class="modal-actions">
      <button class="cancel-btn" bindtap="onClosePaymentModal">
        取消
      </button>
      <button class="submit-btn" bindtap="onSubmitPayment">
        已支付，等待激活
      </button>
    </view>
  </view>
</view>

